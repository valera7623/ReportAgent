# Environment
.env
alertmanager/alertmanager.yml
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/

# SQLite user database (runtime)
app/data/*.db
app/data/*.db-*

# Storage & logs (runtime data)
storage/pdfs/*
!storage/pdfs/.gitkeep
storage/formatted/*
!storage/formatted/.gitkeep
storage/uploads/*
!storage/uploads/.gitkeep
logs/*
!logs/.gitkeep

# Google service account (never commit)
secrets/*
!secrets/.gitkeep

# Traefik ACME
traefik/acme/acme.json

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Docker
*.log
