# --- Application ---
SECRET_KEY=change-me-to-a-long-random-string

# --- Auth (email/password + JWT) ---
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
VERIFICATION_TOKEN_EXPIRE_HOURS=24
RESET_PASSWORD_TOKEN_EXPIRE_HOURS=1
EMAIL_FROM=noreply@reportagent.com
# SPA base URL (hash routes), e.g. https://reportagent.example.com/app
FRONTEND_URL=https://ваш-домен/app
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=25

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_EXPIRES=86400

# Docker images (override if Docker Hub times out)
TRAEFIK_IMAGE=traefik:v3.0
REDIS_IMAGE=redis:7-alpine
# REDIS_IMAGE=public.ecr.aws/docker/library/redis:7-alpine
# PULL_RETRIES=5
# PULL_RETRY_DELAY=20
# SKIP_PULL=1

# --- Database (SQLite user memory) ---
DATABASE_URL=sqlite:///./app/data/users.db
DEFAULT_PREFERRED_CHART_TYPE=bar

# Local dev: skip API key checks (never use in production)
# DISABLE_AUTH=true

# --- Voice input (OpenAI Whisper + GPT intent) ---
OPENAI_API_KEY=sk-...
# ProxyAPI.ru (Russia): https://api.proxyapi.ru/openai/v1
# Leave empty for official api.openai.com
OPENAI_BASE_URL=
WHISPER_MODEL=whisper-1
LLM_MODEL=gpt-4o-mini
VOICE_ENABLED=true
MAX_AUDIO_SIZE_MB=25
ALLOWED_AUDIO_FORMATS=mp3,wav,m4a,ogg

# --- Multi-format output (Step 4) ---
DEFAULT_OUTPUT_FORMAT=pdf
NOTION_INTEGRATION_TOKEN=secret_...
NOTION_DATABASE_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/google-sa.json
GOOGLE_SLIDES_TEMPLATE_ID=
ALLOWED_OUTPUT_FORMATS=pdf,excel,pptx,notion,google_slides

# --- SMTP (email delivery) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=reports@example.com
SMTP_USE_TLS=true

# --- Traefik / TLS ---
# ReportAgent API subdomain (NOT the root domain if another app uses it):
DOMAIN=reportagent.example.com
LETSENCRYPT_EMAIL=admin@example.com
# false = nginx on host already uses 80/443 (see docs/nginx-host.example.conf)
TRAEFIK_ENABLED=true
# If nginx runs in Docker (e.g. smdg-nginx-1), set its compose network name:
# EXTERNAL_NGINX_NETWORK=smdg_default

# Use Let's Encrypt staging for testing (avoids rate limits):
# ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
# Production (default):
ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory

# --- Observability (Prometheus, Grafana, Alertmanager) ---
PROMETHEUS_RETENTION_DAYS=15
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=secure_password_here
GRAFANA_DOMAIN=grafana.example.com
# Traefik basic auth + Grafana login use GRAFANA_ADMIN_PASSWORD
# On 1–2 GB VPS disable host metrics collectors:
# OBSERVABILITY_HOST_METRICS=false

# Telegram alerts (Alertmanager)
TELEGRAM_BOT_TOKEN=123456:ABCdef...
TELEGRAM_CHAT_ID=-123456789
ALERTS_ENABLED=true

# --- Self-healing RAG (Step 5) ---
SELF_HEALING_ENABLED=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./chroma_data
SIMILARITY_THRESHOLD=0.75
MAX_RETRY_ATTEMPTS=2
SELF_HEALING_LOG_LEVEL=info
FIX_ATTEMPT_TIMEOUT_SECONDS=30
# Minimum free RAM (MB) to enable self-healing; 512 for 1–2 GB VPS
SELF_HEALING_MIN_RAM_MB=512
# Admin API (self-healing, users, health, logs)
ADMIN_API_KEY=change-me-generate-on-deploy
ADMIN_LOGS_MAX_LINES=1000
ADMIN_LOGS_ALLOWED_LEVELS=ERROR,WARNING,INFO
ADMIN_RATE_LIMIT_REQUESTS_PER_MINUTE=60
# Optional comma-separated IPs allowed to call /admin/* (empty = any IP)
ADMIN_ALLOWED_IPS=
# Default user rate limit (requests per minute)
RATE_LIMIT_REQUESTS_PER_MINUTE=100
# Docker container name for celery restart endpoint
CELERY_CONTAINER_NAME=reportagent_celery_worker

# --- Webhook notifications ---
WEBHOOK_ENABLED=true
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_RETRY_COUNT=3
WEBHOOK_RETRY_DELAY_SECONDS=5
WEBHOOK_USER_AGENT=ReportAgent-Webhook/1.0
# Public base URL for download_url in webhook payloads (defaults to https://DOMAIN)
WEBHOOK_PUBLIC_BASE_URL=https://reportagent.example.com
WEBHOOK_MAX_CONCURRENT=5
WEBHOOK_FAILURE_DEACTIVATE_THRESHOLD=5

# --- YooKassa Payments (optional, RU) ---
YOOKASSA_SHOP_ID=ваш_shop_id
YOOKASSA_SECRET_KEY=ваш_секретный_ключ
YOOKASSA_API_URL=https://api.yookassa.ru/v3
YOOKASSA_RETURN_URL_SUCCESS=https://ваш-домен/payment/success
YOOKASSA_RETURN_URL_CANCEL=https://ваш-домен/payment/cancel
# Auto-capture two-stage payments on webhook waiting_for_capture
YOOKASSA_AUTO_CAPTURE_ON_WAITING=true

# --- Stripe Payments (primary) ---
# Set BILLING_ENABLED=false to disable limits and checkout while testing
BILLING_ENABLED=true
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_xxx
STRIPE_PRICE_ID_YEARLY=price_yyy
STRIPE_PRICE_ID_PAYG=price_zzz
STRIPE_SUCCESS_URL=https://ваш-домен/success
STRIPE_CANCEL_URL=https://ваш-домен/cancel

# Tariffs (report limits; Stripe prices configured in Dashboard)
FREEMIUM_REPORTS_LIMIT=5
PREMIUM_REPORTS_LIMIT=100
ENTERPRISE_REPORTS_LIMIT=1000
# YooKassa fallback prices in kopeks
PRICE_PREMIUM_MONTHLY=1990
PRICE_PREMIUM_YEARLY=19900
PRICE_ENTERPRISE=9990
