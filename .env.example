# --- Application ---
SECRET_KEY=change-me-to-a-long-random-string
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=25

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_EXPIRES=86400

# Docker images (override if Docker Hub times out)
TRAEFIK_IMAGE=traefik:v3.0
REDIS_IMAGE=redis:7-alpine
# REDIS_IMAGE=public.ecr.aws/docker/library/redis:7-alpine
# PULL_RETRIES=5
# PULL_RETRY_DELAY=20
# SKIP_PULL=1

# --- Database (reserved for future use) ---
DATABASE_URL=postgresql://user:password@localhost:5432/reportagent

# --- SMTP (email delivery) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=reports@example.com
SMTP_USE_TLS=true

# --- Traefik / TLS ---
DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com
# false = nginx on host already uses 80/443 (see docs/nginx-host.example.conf)
TRAEFIK_ENABLED=true
# If nginx runs in Docker (e.g. smdg-nginx-1), set its compose network name:
# EXTERNAL_NGINX_NETWORK=smdg_default

# Use Let's Encrypt staging for testing (avoids rate limits):
# ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
# Production (default):
ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory
